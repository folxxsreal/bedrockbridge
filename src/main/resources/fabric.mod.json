{
	"schemaVersion": 1,
	"id": "bedrockbridge",
	"version": "${version}",
	"name": "BedrockBridge",
	"description": "Share your Minecraft Java world with Bedrock players in a single click.",
	"authors": [
		"folxxsreal"
	],
	"contact": {
		"homepage": "https://github.com/folxxsreal/bedrockbridge"
	},
	"license": "MIT",
	"icon": "assets/bedrockbridge/icon.png",
	"environment": "*",
	"entrypoints": {
		"preLaunch": [
			"com.minecraftbridge.BedrockBridgePreLaunch"
		],
		"main": [
			"com.minecraftbridge.BedrockBridge"
		],
		"client": [
			"com.minecraftbridge.client.BedrockBridgeClient"
		]
	},
	"mixins": [
		"bedrockbridge.mixins.json",
		{
			"config": "bedrockbridge.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	},
	"jars": [
		{ "file": "META-INF/jars/Geyser-Fabric-1153.jar" },
		{ "file": "META-INF/jars/Floodgate-Fabric-2.2.6-b63.jar" }
	]
}